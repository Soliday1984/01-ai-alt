{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "imageseofix",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "limits": {
    "cpu_ms": 20,
    "subrequests": 5
  },
  "observability": {
    "enabled": true
  }
}
